---
import stateConfig from '~@/slate.config';
import type { ThemeOptions } from '@/typings/config';
import ThemeSelect from '@/components/theme-select';
import SocialLinks from '@/components/social-links';
import slateConfig from '~@/slate.config';

import { getWeather } from "../weather/getWeather";

interface Props {
  copyright?: string;
}

const { copyright = stateConfig.footer?.copyright } = Astro.props;

//get weather data for Doncaster, Tamsui, and Yuen Long
const doncaster = await getWeather(53.5228, -1.1285);
const tamsui = await getWeather(25.1719, 121.4434);
const yuenLong = await getWeather(22.4445, 114.0222);

const cities = [
  { name: "Doncaster", data: doncaster },
  { name: "Tamsui", data: tamsui },
  { name: "Yuen Long", data: yuenLong },
];


---

<footer class="mt-auto">
  {!!slateConfig.socialLinks && <SocialLinks client:visible />}
  <div class="mt-4 flex items-center justify-between">
    <div>
      <div class="text-slate8 text-sm">{copyright}</div>
      {cities.map((city) =>
        city.data && (
          <div class="text-slate8 text-sm">
            {city.name} {city.data.temp}℃
          </div>
        )
      )}
    </div>
    {/* S theme selection */}
    {(stateConfig.theme as ThemeOptions).enableUserChange && <ThemeSelect  client:visible />}
    {/* E theme selection */}
  </div>
</footer>
